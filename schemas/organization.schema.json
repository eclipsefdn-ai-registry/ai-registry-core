{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Organization",
  "description": "Vendor organization metadata for the AI Registry",
  "type": "object",
  "required": ["id", "name", "description", "website", "tools"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier for the organization (lowercase, alphanumeric, hyphens)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the organization"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of the organization"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Organization website URL"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Brand color in hex format (e.g., #1a1f71)"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "description": "Tools this vendor provides",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique identifier for the tool"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Display name of the tool"
          }
        }
      }
    }
  }
}
